#!/usr/bin/env bash
# agp — Agent Profile Manager
# Manages isolated AI tool profiles on macOS.
# Version: 1.0.0
#
# Usage: agp <command> [args]
#   agp create <name> [--desc "..."]
#   agp list
#   agp delete <name> [-f]
#   agp open <name> <tool> [tool-args...]
#   agp shell <name>
#   agp env <name>
#   agp install

set -uo pipefail

# ─── Constants ───────────────────────────────────────────────────────────────

AGP_VERSION="1.0.0"
AGP_PROFILES_DIR="${AGP_PROFILES_DIR:-${HOME}/.agent-profiles}"

VALID_TOOLS=("claude" "claude-desktop" "codex" "codex-desktop" "gemini" "gemini-desktop" "antigravity")
PROFILE_SUBDIRS=("claude" "codex" "gemini" "antigravity")

# ─── Colors ──────────────────────────────────────────────────────────────────

_setup_colors() {
  if [ -t 2 ]; then
    RESET='\033[0m'; BOLD='\033[1m'; DIM='\033[2m'
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
    BLUE='\033[0;34m'; MAGENTA='\033[0;35m'; CYAN='\033[0;36m'
    WHITE='\033[1;37m'
  else
    RESET=''; BOLD=''; DIM=''
    RED=''; GREEN=''; YELLOW=''
    BLUE=''; MAGENTA=''; CYAN=''; WHITE=''
  fi
}
_setup_colors

info()    { printf "${BLUE}  info${RESET}  %s\n" "$*" >&2; }
warn()    { printf "${YELLOW}  warn${RESET}  %s\n" "$*" >&2; }
success() { printf "${GREEN}    ok${RESET}  %s\n" "$*" >&2; }
error()   { printf "${RED} error${RESET}  %s\n" "$*" >&2; exit 1; }
dim()     { printf "${DIM}%s${RESET}\n" "$*" >&2; }
header()  { printf "\n${BOLD}${WHITE}%s${RESET}\n" "$*" >&2; }

# ─── Profile helpers ─────────────────────────────────────────────────────────

profile_path() {
  echo "${AGP_PROFILES_DIR}/$1"
}

profile_exists() {
  [ -d "$(profile_path "$1")" ]
}

validate_name() {
  local name="$1"
  if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    error "Invalid profile name '${name}'. Use only letters, numbers, hyphens and underscores."
  fi
  local reserved=("list" "create" "delete" "open" "shell" "env" "install" "help")
  for r in "${reserved[@]}"; do
    if [ "$name" = "$r" ]; then
      error "Profile name '${name}' is reserved. Choose a different name."
    fi
  done
}

write_profile_toml() {
  local path="$1" name="$2" desc="$3"
  local created
  created="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  cat > "${path}/profile.toml" <<EOF
name = "${name}"
description = "${desc}"
created = "${created}"
EOF
}

read_profile_field() {
  local toml="$1" field="$2"
  grep -m1 "^${field} = " "$toml" 2>/dev/null | sed 's/^[^=]*= "\(.*\)"$/\1/' || echo ""
}

# ─── App helpers ─────────────────────────────────────────────────────────────

app_installed() {
  local app="${1%.app}"
  local app_dir="${app}.app"
  [ -d "/Applications/${app_dir}" ] || [ -d "${HOME}/Applications/${app_dir}" ]
}

find_app_path() {
  local app="${1%.app}"
  local app_dir="${app}.app"
  if [ -d "/Applications/${app_dir}" ]; then
    echo "/Applications/${app_dir}"
  elif [ -d "${HOME}/Applications/${app_dir}" ]; then
    echo "${HOME}/Applications/${app_dir}"
  fi
}

cli_installed() {
  command -v "$1" >/dev/null 2>&1
}

warn_first_login() {
  local provider_dir="$1"
  # Heuristic: if Cookies file doesn't exist, this profile has never logged in
  if [ ! -f "${provider_dir}/Cookies" ] && [ ! -f "${provider_dir}/Default/Cookies" ]; then
    printf "\n${YELLOW}${BOLD}  First login detected for this profile${RESET}\n" >&2
    printf "${YELLOW}  Before clicking Sign In:${RESET}\n" >&2
    printf "${DIM}  1. Temporarily set your default browser to a secondary browser\n" >&2
    printf "     (System Settings → Desktop & Dock → Default web browser)\n" >&2
    printf "  2. Click Sign In — authenticate in that secondary browser\n" >&2
    printf "  3. Restore your original default browser\n${RESET}\n" >&2
  fi
}

open_desktop_app() {
  local app_name="${1%.app}"
  local profile_dir="$2"
  if ! app_installed "${app_name}"; then
    error "${app_name} not found in /Applications or ~/Applications."
  fi
  warn_first_login "$profile_dir"
  info "Opening ${app_name} with profile at ${profile_dir}"
  open -n -a "${app_name}" --args --user-data-dir="${profile_dir}" &
  disown
}

# ─── Commands ────────────────────────────────────────────────────────────────

cmd_create() {
  local name="" desc=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --desc|-d) shift; desc="${1:-}"; shift ;;
      --help|-h) usage_create; return 0 ;;
      -*) error "Unknown option: $1" ;;
      *) name="$1"; shift ;;
    esac
  done

  [ -z "$name" ] && { usage_create; exit 1; }
  validate_name "$name"

  if profile_exists "$name"; then
    error "Profile '${name}' already exists. Run 'agp list' to see all profiles."
  fi

  local p
  p="$(profile_path "$name")"

  for subdir in "${PROFILE_SUBDIRS[@]}"; do
    mkdir -p "${p}/${subdir}"
  done

  write_profile_toml "$p" "$name" "$desc"

  success "Created profile '${name}' at ${p}"
  dim "  Next: agp open ${name} claude"
}

cmd_list() {
  if [ ! -d "$AGP_PROFILES_DIR" ] || [ -z "$(ls -A "$AGP_PROFILES_DIR" 2>/dev/null)" ]; then
    info "No profiles found. Create one with: agp create <name>"
    return 0
  fi

  local active="${AGP_ACTIVE_PROFILE:-}"
  local name_w=16 desc_w=28

  printf "\n${BOLD}${WHITE}%-${name_w}s  %-${desc_w}s  %s${RESET}\n" "NAME" "DESCRIPTION" "CREATED" >&2
  printf "${DIM}%s${RESET}\n" "$(printf '─%.0s' {1..60})" >&2

  local found=0
  for dir in $(ls -d "${AGP_PROFILES_DIR}/"*/ 2>/dev/null | sort); do
    local pname
    pname="$(basename "$dir")"
    local toml="${dir}profile.toml"
    local pdesc pcreated marker=""

    if [ -f "$toml" ]; then
      pdesc="$(read_profile_field "$toml" "description")"
      pcreated="$(read_profile_field "$toml" "created")"
      pcreated="${pcreated%T*}"  # keep date only
    else
      pdesc="(no metadata)"
      pcreated="?"
    fi

    if [ "$pname" = "$active" ]; then
      marker="${GREEN}*${RESET} "
      printf "${GREEN}%-$((name_w - 2))s${RESET}  %-${desc_w}s  ${DIM}%s${RESET}\n" \
        "${marker}${pname}" "${pdesc:-}" "${pcreated:-}" >&2
    else
      printf "  %-$((name_w - 2))s  %-${desc_w}s  ${DIM}%s${RESET}\n" \
        "${pname}" "${pdesc:-}" "${pcreated:-}" >&2
    fi
    found=1
  done

  [ $found -eq 0 ] && info "No profiles found."
  printf "\n" >&2
}

cmd_delete() {
  local name="" force=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force) force=1; shift ;;
      --help|-h) usage_delete; return 0 ;;
      -*) error "Unknown option: $1" ;;
      *) name="$1"; shift ;;
    esac
  done

  [ -z "$name" ] && { usage_delete; exit 1; }

  if ! profile_exists "$name"; then
    error "Profile '${name}' not found."
  fi

  local p
  p="$(profile_path "$name")"

  if [ $force -eq 0 ]; then
    printf "${YELLOW}  warn${RESET}  Delete profile '${BOLD}${name}${RESET}' at ${DIM}${p}${RESET}?\n" >&2
    printf "        This is irreversible. Type 'yes' to confirm: " >&2
    local answer
    read -r answer
    if [ "$answer" != "yes" ]; then
      info "Aborted."
      return 0
    fi
  fi

  rm -rf "$p"
  success "Deleted profile '${name}'."
}

cmd_open() {
  local name="${1:-}" tool="${2:-}"

  if [ -z "$name" ] || [ -z "$tool" ] || [ "$name" = "--help" ] || [ "$name" = "-h" ]; then
    usage_open; [ "$name" = "--help" ] || [ "$name" = "-h" ] && return 0 || exit 1
  fi

  if ! profile_exists "$name"; then
    error "Profile '${name}' not found. Run 'agp list' to see available profiles."
  fi

  # Validate tool
  local valid=0
  for t in "${VALID_TOOLS[@]}"; do [ "$t" = "$tool" ] && valid=1 && break; done
  [ $valid -eq 0 ] && error "Unknown tool '${tool}'. Valid tools: ${VALID_TOOLS[*]}"

  local p
  p="$(profile_path "$name")"
  shift 2  # consume <name> <tool>, remaining args go to the CLI

  case "$tool" in
    claude)
      if ! cli_installed claude; then
        error "'claude' CLI not found. Install from https://claude.ai/download"
      fi
      info "Opening claude CLI under profile '${name}'"
      CLAUDE_CONFIG_DIR="${p}/claude" exec claude "$@"
      ;;

    claude-desktop)
      open_desktop_app "Claude" "${p}/claude"
      ;;

    codex)
      if ! cli_installed codex; then
        error "'codex' CLI not found. Install with: npm install -g @openai/codex"
      fi
      info "Opening codex CLI under profile '${name}'"
      CODEX_HOME="${p}/codex" exec codex "$@"
      ;;

    codex-desktop)
      if ! app_installed "Codex"; then
        error "Codex not found in /Applications or ~/Applications."
      fi
      local codex_bin
      codex_bin="$(find_app_path "Codex")/Contents/MacOS/Codex"
      warn_first_login "${p}/codex"
      info "Opening Codex with profile '${name}'"
      nohup env CODEX_HOME="${p}/codex" "$codex_bin" >/dev/null 2>&1 &
      disown $!
      ;;

    gemini)
      if ! cli_installed gemini; then
        error "'gemini' CLI not found. Install with: npm install -g @google/gemini-cli"
      fi
      info "Opening gemini CLI under profile '${name}'"
      GEMINI_CLI_HOME="${p}/gemini" exec gemini "$@"
      ;;

    gemini-desktop)
      # If a separate Gemini Desktop app exists, use it; otherwise hint
      if app_installed "Gemini"; then
        open_desktop_app "Gemini" "${p}/gemini"
      else
        warn "Gemini Desktop app not found. Try 'agp open ${name} antigravity' instead."
      fi
      ;;

    antigravity)
      open_desktop_app "Antigravity" "${p}/antigravity"
      ;;
  esac
}

cmd_shell() {
  local name="${1:-}"
  [ -z "$name" ] || [ "$name" = "--help" ] || [ "$name" = "-h" ] && { usage_shell; exit 1; }

  if ! profile_exists "$name"; then
    error "Profile '${name}' not found."
  fi

  local p
  p="$(profile_path "$name")"
  local current_profile="${AGP_ACTIVE_PROFILE:-}"

  if [ -n "$current_profile" ]; then
    warn "Already in profile '${current_profile}'. Starting nested shell with profile '${name}'."
  fi

  printf "\n${BOLD}${CYAN}  agp${RESET}${BOLD}  Entering profile '${name}'${RESET}\n" >&2
  printf "${DIM}        CLAUDE_CONFIG_DIR=${p}/claude\n" >&2
  printf "        CODEX_HOME=${p}/codex\n" >&2
  printf "        GEMINI_CLI_HOME=${p}/gemini\n" >&2
  printf "        Exit with: exit or Ctrl-D${RESET}\n\n" >&2

  exec env \
    CLAUDE_CONFIG_DIR="${p}/claude" \
    CODEX_HOME="${p}/codex" \
    GEMINI_CLI_HOME="${p}/gemini" \
    AGP_ACTIVE_PROFILE="${name}" \
    AGP_PROFILE_DIR="${p}" \
    AGENTIC_PROFILE="${name}" \
    "${SHELL:-/bin/zsh}"
}

cmd_env() {
  local name="${1:-}"
  [ -z "$name" ] || [ "$name" = "--help" ] || [ "$name" = "-h" ] && { usage_env >&2; exit 1; }

  if ! profile_exists "$name"; then
    printf "# error: profile '%s' not found\n" "$name"
    exit 1
  fi

  local p
  p="$(profile_path "$name")"

  # Stdout only — no colors, no extra output (safe for eval)
  printf '# agp profile: %s\n' "$name"
  printf 'export CLAUDE_CONFIG_DIR="%s/claude"\n' "$p"
  printf 'export CODEX_HOME="%s/codex"\n' "$p"
  printf 'export GEMINI_CLI_HOME="%s/gemini"\n' "$p"
  printf 'export AGP_ACTIVE_PROFILE="%s"\n' "$name"
  printf 'export AGP_PROFILE_DIR="%s"\n' "$p"
  printf 'export AGENTIC_PROFILE="%s"\n' "$name"
}

cmd_install() {
  local script_path
  script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
  local target="${HOME}/.local/bin/agp"

  chmod +x "$script_path"
  mkdir -p "${HOME}/.local/bin"
  ln -sf "$script_path" "$target"
  success "Installed: ${target} -> ${script_path}"
  dim "  Make sure ${HOME}/.local/bin is in your PATH."
}

# ─── Help ────────────────────────────────────────────────────────────────────

usage() {
  cat >&2 <<EOF

${BOLD}agp${RESET} ${DIM}v${AGP_VERSION}${RESET} — Agent Profile Manager

${BOLD}USAGE${RESET}
  agp <command> [arguments]

${BOLD}COMMANDS${RESET}
  ${CYAN}create${RESET} <name> [--desc "..."]   Create a new isolated profile
  ${CYAN}list${RESET}                           List all profiles
  ${CYAN}delete${RESET} <name> [-f]             Delete a profile
  ${CYAN}open${RESET}   <name> <tool> [args]    Open a tool under a profile
  ${CYAN}shell${RESET}  <name>                  Start a shell with profile env
  ${CYAN}env${RESET}    <name>                  Print export statements (for eval)
  ${CYAN}install${RESET}                        Symlink agp to ~/.local/bin/agp

${BOLD}TOOLS${RESET} (for agp open)
  claude          Claude CLI
  claude-desktop  Claude Desktop app
  codex           Codex CLI
  codex-desktop   Codex Desktop app
  gemini          Gemini CLI
  gemini-desktop  Gemini Desktop app
  antigravity     Antigravity Desktop app (Google)

${BOLD}PROFILE STRUCTURE${RESET}
  ~/${AGP_PROFILES_DIR}/<name>/
  ├── profile.toml    metadata
  ├── claude/         Claude context (CLI + desktop)
  ├── codex/          Codex context (CLI + desktop)
  ├── gemini/         Gemini CLI context
  └── antigravity/    Antigravity context

${BOLD}EXAMPLES${RESET}
  agp create personal --desc "Personal AI workspace"
  agp create work --desc "Work account"
  agp list
  agp open personal claude
  agp open work claude-desktop
  agp shell personal
  eval "\$(agp env personal)"

${BOLD}ENV${RESET}
  AGP_PROFILES_DIR   Override profiles base dir (default: ~/.agent-profiles)

EOF
}

usage_create() {
  cat >&2 <<EOF
${BOLD}agp create${RESET} <name> [--desc "description"]

Create a new isolated profile with separate directories for each AI tool provider.

${BOLD}OPTIONS${RESET}
  --desc, -d   Short description for the profile

${BOLD}EXAMPLES${RESET}
  agp create personal
  agp create work --desc "Acme Corp account"
EOF
}

usage_open() {
  cat >&2 <<EOF
${BOLD}agp open${RESET} <name> <tool> [tool-args...]

Open an AI tool under an isolated profile. Any extra arguments are forwarded
to the underlying CLI tool.

${BOLD}TOOLS${RESET}
  claude          CLAUDE_CONFIG_DIR=<profile>/claude  claude [args]
  claude-desktop  open -n "Claude" --user-data-dir=<profile>/claude
  codex           CODEX_HOME=<profile>/codex  codex [args]
  codex-desktop   open -n "Codex" --user-data-dir=<profile>/codex
  gemini          GEMINI_CLI_HOME=<profile>/gemini  gemini [args]
  gemini-desktop  open -n "Gemini" --user-data-dir=<profile>/gemini
  antigravity     open -n "Antigravity" --user-data-dir=<profile>/antigravity

${BOLD}EXAMPLES${RESET}
  agp open personal claude
  agp open work claude-desktop
  agp open personal gemini --model gemini-2.0-flash
  agp open work antigravity
EOF
}

usage_delete() {
  cat >&2 <<EOF
${BOLD}agp delete${RESET} <name> [-f]

Delete a profile and all its data. Prompts for confirmation unless -f is given.

${BOLD}OPTIONS${RESET}
  -f, --force   Skip confirmation prompt

${BOLD}EXAMPLES${RESET}
  agp delete old-profile
  agp delete old-profile -f
EOF
}

usage_shell() {
  cat >&2 <<EOF
${BOLD}agp shell${RESET} <name>

Start a new interactive shell with the profile's environment variables pre-loaded.
All AI CLI tools launched from this shell will use the profile's isolated config.

Exit with: exit or Ctrl-D

${BOLD}EXAMPLES${RESET}
  agp shell personal
  agp shell work
EOF
}

usage_env() {
  cat >&2 <<EOF
${BOLD}agp env${RESET} <name>

Print shell export statements to stdout for the given profile.
Designed for use with eval to load a profile into the current shell session.

${BOLD}EXAMPLES${RESET}
  eval "\$(agp env personal)"
  agp env work >> .envrc
EOF
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
  if [ $# -eq 0 ]; then
    usage
    exit 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    create)         cmd_create "$@" ;;
    list|ls)        cmd_list "$@" ;;
    delete|rm)      cmd_delete "$@" ;;
    open)           cmd_open "$@" ;;
    shell)          cmd_shell "$@" ;;
    env)            cmd_env "$@" ;;
    install)        cmd_install "$@" ;;
    -h|--help|help) usage; exit 0 ;;
    -v|--version)   echo "agp ${AGP_VERSION}"; exit 0 ;;
    *) printf "${RED} error${RESET}  Unknown command: %s. Run 'agp --help' for usage.\n" "$cmd" >&2; exit 1 ;;
  esac
}

main "$@"
